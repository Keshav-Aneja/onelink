{
  "name": "@onelink/db",
  "main": "index.ts",
  "types": "./src/types/knex.d.ts",
  "files": [
    "src",
    "types",
    "knex.d.ts"
  ],
  "scripts": {
    "db:make": "bun knex --migrations-directory ./src/migrations migrate:make -x ts",
    "db:latest": "NODE_OPTIONS='--import tsx/esm' bun knex migrate:latest --knexfile ./src/knexfile.cjs",
    "db:up": "NODE_OPTIONS='--import tsx/esm' bun knex --knexfile ./src/knexfile.cjs migrate:up",
    "db:down": "NODE_OPTIONS='--import tsx/esm' bun knex migrate:down --knexfile ./src/knexfile.cjs",
    "db:rollback": "NODE_OPTIONS='--import tsx/esm' bun knex migrate:rollback --knexfile ./src/knexfile.cjs",
    "db:list": "NODE_OPTIONS='--import tsx/esm' bun knex migrate:list --knexfile ./src/knexfile.cjs"
  },
  "devDependencies": {
    "@onelink/typescript-config": "workspace:*",
    "@types/bun": "latest",
    "knex": "^3.1.0"
  },
  "dependencies": {
    "@onelink/entities": "workspace:*",
    "better-sqlite3": "^11.9.1",
    "mysql": "^2.18.1",
    "mysql2": "^3.14.0",
    "oracledb": "^6.8.0",
    "pg": "^8.13.3",
    "pg-query-stream": "^4.8.1",
    "sqlite3": "^5.1.7",
    "tedious": "^18.6.1"
  },
  "exports": {
    ".": "./index.ts"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "private": true,
  "type": "module"
}
